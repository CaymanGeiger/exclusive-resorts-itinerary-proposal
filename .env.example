# Server-only Resend credentials. Leave blank for simulated email.
RESEND_API_KEY=
PROPOSAL_FROM_EMAIL=

# Optional: route all proposal emails to a real address during demos.
PROPOSAL_EMAIL_TO_OVERRIDE=

# Optional local fallback when an API request origin is unavailable.
PROPOSAL_BASE_URL=http://localhost:3015

# Optional SQLite override. Vercel defaults to /tmp/exclusive-resorts.sqlite.
SQLITE_DATABASE_PATH=
